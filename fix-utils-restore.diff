+def _normalize_to_dict(obj: Any) -> Dict:
+    if obj is None:
+        return {}
+    if isinstance(obj, dict):
+        return obj
+    if isinstance(obj, str):
+        s = obj.strip()
+        if not s:
+            return {}
+        try:
+            parsed = json.loads(s)
+            return parsed if isinstance(parsed, dict) else {"value": parsed}
+        except Exception:
+            return {"value": s}
+    try:
+        return dict(obj)
+    except Exception:
+        return {"value": str(obj)}
