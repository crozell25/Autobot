diff --git a/strategies/aero_aggressive_scalper.py b/strategies/aero_aggressive_scalper.py
index e69de29..c3d4e5f 100644
--- a/strategies/aero_aggressive_scalper.py
+++ b/strategies/aero_aggressive_scalper.py
@@ -1,6 +1,28 @@
+import uuid
+import logging
+from decimal import Decimal
+from typing import Any, Dict
+from utils import format_by_increment
+
+logger = logging.getLogger("AggressiveScalper")
+
+# Constants
+SELL_SIZE = Decimal("0.1")
+BUY_SIZE = Decimal("0.1")
+MAX_SELL_ORDERS = 60
+MAX_BUY_ORDERS = 20
+STP_NAMESPACE = uuid.UUID("6ba7b810-9dad-11d1-80b4-00c04fd430c8")
+STALE_THRESHOLD_PCT = Decimal("0.01")  # 1%
+
+def run_strategy(order_manager, market_data):
+    portfolio_id = market_data.get("portfolio_id")
+    product_id = market_data.get("product_id", "AERO-USDC")
+    mid_price = Decimal(str(market_data.get("price", "0")))
+    # Prefer explicit tick size from market_data; fallback to sensible default
+    tick_size = Decimal(str(market_data.get("tick_size", "0.00001")))
+    best_ask = market_data.get("best_ask")
+    best_bid = market_data.get("best_bid")
+
+    if mid_price <= 0 or not portfolio_id:
+        return
+
+    active_orders = [o for o in order_manager.active_orders.values()
+                     if o.get("portfolio_id") == portfolio_id and o.get("product_id") == product_id]
+
+    sell_orders = [o for o in active_orders if o.get("side") == "SELL"]
+    buy_orders = [o for o in active_orders if o.get("side") == "BUY"]
+
+    # Recalculate fresh count after potential prunes
+    fresh_sell_orders = [o for o in sell_orders if abs(Decimal(str(o.get("price", "0"))) - mid_price) / mid_price <= STALE_THRESHOLD_PCT]
+    fresh_buy_orders = [o for o in buy_orders if abs(Decimal(str(o.get("price", "0"))) - mid_price) / mid_price <= STALE_THRESHOLD_PCT]
+
+    # --- 3. Manage Aggressive Taker Buy ---
+    if len(fresh_buy_orders) < MAX_BUY_ORDERS:
+        # Taker: cross the best ask by one tick if available; otherwise use mid_price
+        if best_ask:
+            taker_price = Decimal(str(best_ask)) + tick_size
+        else:
+            taker_price = mid_price
+
+        formatted_taker_price = format_by_increment(taker_price, tick_size)
+        # Flood protection: avoid placing duplicate buy at same price
+        already_buy = any(str(o.get("price")) == formatted_taker_price and o.get("side") == "BUY" for o in active_orders)
+        if not already_buy:
+            order_manager.enqueue({
+                "action": "PLACE_ORDER",
+                "source_pid": portfolio_id,
+                "client_order_id": str(uuid.uuid4()),
+                "product_id": product_id,
+                "side": "BUY",
+                "price": str(formatted_taker_price),
+                "size": str(BUY_SIZE),
+                "post_only": False,  # Taker order to cross spread
+                "stp_id": str(uuid.uuid4())
+            })
+
+    # --- 4. Manage Sell Ladder (Maker) ---
+    if len(fresh_sell_orders) < 50:
+        target_price = mid_price * Decimal("1.001")  # 0.1% spread
+        formatted_price = format_by_increment(target_price, tick_size)
+        client_order_id = str(uuid.uuid5(STP_NAMESPACE, f"{portfolio_id}_SELL_{formatted_price}"))
+
+        # Avoid duplicate deterministic sell at same price across active and queued tasks
+        already_sell = any(o.get("client_order_id") == client_order_id for o in active_orders)
+        if not already_sell:
+            order_manager.enqueue({
+                "action": "PLACE_ORDER",
+                "source_pid": portfolio_id,
+                "client_order_id": client_order_id,
+                "product_id": product_id,
+                "side": "SELL",
+                "price": str(formatted_price),
+                "size": str(SELL_SIZE),
+                "post_only": True,  # Maker order
+                "stp_id": str(uuid.uuid5(STP_NAMESPACE, f"{portfolio_id}_STP_SELL_{formatted_price}"))
+            })
+
+    # rest of strategy...
+
