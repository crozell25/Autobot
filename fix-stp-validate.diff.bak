@@ -1,6 +1,28 @@
 import os
 import time
 import logging
+from urllib.parse import urlparse
 import asyncio
 import requests
 import json
 from decimal import Decimal, ROUND_DOWN
 from typing import Any, Dict, Optional
+from decimal import InvalidOperation
+
+logger = logging.getLogger(__name__)
+
+def validate_and_quantize(price, size, tick_size, format_by_increment_fn):
+    """
+    Validate numeric order params and quantize price to tick_size.
+    Returns (Decimal(price_q), Decimal(size_d)) or (None, None) on invalid input.
+    """
+    try:
+        price_d = price if isinstance(price, Decimal) else Decimal(str(price))
+        size_d = size if isinstance(size, Decimal) else Decimal(str(size))
+    except (InvalidOperation, TypeError, ValueError):
+        logger.warning("Rejecting order: invalid numeric params price=%s size=%s", price, size)
+        return None, None
+    if price_d <= 0 or size_d <= 0:
+        logger.warning("Rejecting order: non-positive price/size price=%s size=%s", price_d, size_d)
+        return None, None
+    try:
+        price_q = Decimal(format_by_increment_fn(price_d, tick_size))
+    except Exception:
+        logger.exception("Quantize failed for price=%s tick=%s", price_d, tick_size)
+        return None, None
+    return price_q, size_d
+
+def would_self_match(side: str, price_q: Decimal, active_orders: list) -> bool:
+    """
+    Conservative check: returns True if placing `side` at price_q would match an existing opposite order.
+    active_orders is a list of order dicts for the same portfolio/product.
+    """
+    from decimal import Decimal as _D
+    if side == "BUY":
+        return any(
+            o for o in active_orders
+            if o.get("side") == "SELL" and _D(str(o.get("price", "0"))) <= price_q
+        )
+    return any(
+        o for o in active_orders
+        if o.get("side") == "BUY" and _D(str(o.get("price", "0"))) >= price_q
+    )
+
+def _extract_path_segment(endpoint: str) -> str:
+    """
+    Safely extract the last path segment from an endpoint URL or path.
+    Handles query strings and trailing slashes.
+    """
+    try:
+        parsed = urlparse(endpoint)
+        path = parsed.path or endpoint
+        return path.rstrip("/").split("/")[-1]
+    except Exception:
+        return endpoint.split("/")[-1] if "/" in endpoint else endpoint
@@
